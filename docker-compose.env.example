# 复制为 .env.compose（勿提交仓库）后使用：
#   cp docker-compose.env.example .env.compose
#   docker compose --env-file .env.compose up -d --build
#
# 不指定 --env-file 时，compose 会合并项目根目录的 .env（若存在）与下列默认值。

# 必填：至少 16 字符（与后端 config 校验一致）
JWT_SECRET=change-me-use-a-long-random-string-in-production

# 可选：覆盖 compose 默认值
# MYSQL_ROOT_PASSWORD=rootsecret
# MYSQL_USER=alioth
# MYSQL_PASSWORD=aliothsecret
# MYSQL_DATABASE=alioth_hrc
# MYSQL_PORT=3306
# REDIS_PORT=6379
# WEB_PORT=8080
# APP_ENV=prod
# CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
