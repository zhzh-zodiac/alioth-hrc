APP_NAME=alioth-hrc
APP_ENV=dev
HTTP_PORT=8080

JWT_SECRET=change-me-min-16-chars-long
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_HOURS=168

# 浏览器前端 Origin，逗号分隔（Vite 默认 5173）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MYSQL_DSN=username:password@tcp(127.0.0.1:3306)/alioth_hrc?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_MAX_IDLE_CONNS=10
MYSQL_MAX_OPEN_CONNS=50
MYSQL_CONN_MAX_LIFETIME_MIN=30

REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=password
REDIS_DB=0
